# QRadar MCP Server - Environment Variables
# Copy this file to .env and fill in your values: cp .env.example .env

# QRadar host URL (e.g., https://qradar.example.com)
QRADAR_HOST=

# QRadar API token (SEC token from Admin > Authorized Services)
QRADAR_API_TOKEN=

# SSL verification (set to true for production, false for self-signed certs)
QRADAR_VERIFY_SSL=false

# API key for HTTP mode security (required for container/SSE mode)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=

# VS Code MCP Config (used by .vscode/mcp.json template)
MCP_SERVER_HOST=       # IP/hostname where container runs (e.g. localhost, 9.30.x.x)
